# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=true
API_BASE_URL=http://localhost:8000

# ============================================================================
# GOOGLE OAUTH CREDENTIALS
# ============================================================================
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: 
# - https://www.googleapis.com/auth/webmasters.readonly (Google Search Console)
# - https://www.googleapis.com/auth/analytics.readonly (Google Analytics 4)

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# ENCRYPTION
# ============================================================================
# Generate a secure 32-byte key for encrypting OAuth tokens stored in database
# Python command to generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ============================================================================
# SESSION & SECURITY
# ============================================================================
# Generate a secure random string for JWT signing
# Python command: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-for-jwt-signing

# ============================================================================
# EXTERNAL API KEYS (for future phases)
# ============================================================================
# DataForSEO credentials (not needed for Phase 1)
# DATAFORSEO_LOGIN=your-dataforseo-login
# DATAFORSEO_PASSWORD=your-dataforseo-password

# Claude API for LLM synthesis (not needed for Phase 1)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# CORS SETTINGS
# ============================================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# DATABASE
# ============================================================================
# Supabase provides PostgreSQL connection string
# Format: postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres